{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "pdf-processor.js",
      "use": "@vercel/static"
    },
    {
      "src": "favicon.svg",
      "use": "@vercel/static"
    },
    {
      "src": "logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "logo.png",
      "use": "@vercel/static"
    },
    {
      "src": "blog-ilovepdf.png",
      "use": "@vercel/static"
    },
    {
      "src": "blog-compress.png",
      "use": "@vercel/static"
    },
    {
      "src": "blog-merge.png",
      "use": "@vercel/static"
    },
    {
      "src": "og-image.svg",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/styles\\.css",
      "dest": "/styles.css"
    },
    {
      "src": "/pdf-processor\\.js",
      "dest": "/pdf-processor.js"
    },
    {
      "src": "/favicon\\.svg",
      "dest": "/favicon.svg"
    },
    {
      "src": "/logo\\.svg",
      "dest": "/logo.svg"
    },
    {
      "src": "/logo\\.png",
      "dest": "/logo.png"
    },
    {
      "src": "/blog-ilovepdf\\.png",
      "dest": "/blog-ilovepdf.png"
    },
    {
      "src": "/blog-compress\\.png",
      "dest": "/blog-compress.png"
    },
    {
      "src": "/blog-merge\\.png",
      "dest": "/blog-merge.png"
    },
    {
      "src": "/og-image\\.svg",
      "dest": "/og-image.svg"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
