{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/styles\\.css",
      "dest": "/styles.css"
    },
    {
      "src": "/pdf-processor\\.js",
      "dest": "/pdf-processor.js"
    },
    {
      "src": "/favicon\\.svg",
      "dest": "/favicon.svg"
    },
    {
      "src": "/logo\\.svg",
      "dest": "/logo.svg"
    },
    {
      "src": "/og-image\\.svg",
      "dest": "/og-image.svg"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
